{% doc %}
  @prompt
    Can you create a block with a header text to begin my webpage, somehting like, 3 ways to begin or begin here or explore your options. add this underneath the hero but on top of the 3 card carousel. make it look professional and aesthetically pleasing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-section-header-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    text-align: {{ block.settings.text_alignment }};
    display: block;
  }

  .ai-section-header__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing_between_elements }}px;
    align-items: {{ block.settings.text_alignment }};
  }

  .ai-section-header__overline-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.overline_size }}px;
    color: {{ block.settings.overline_color }};
    text-transform: {{ block.settings.overline_transform }};
    letter-spacing: {{ block.settings.overline_letter_spacing }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-section-header__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-transform: {{ block.settings.heading_transform }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    margin: 0;
    line-height: 1.2;
  }

  .ai-section-header__subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    letter-spacing: {{ block.settings.subheading_letter_spacing }}px;
    margin: 0;
    line-height: 1.6;
    max-width: {{ block.settings.subheading_max_width }}px;
  }

  .ai-section-header__divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    border: none;
    margin: 0;
    {% if block.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif block.settings.text_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-section-header-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 16px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-section-header__overline-{{ ai_gen_id }} {
      font-size: {{ block.settings.overline_size | times: 0.85 }}px;
    }

    .ai-section-header__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-section-header__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-section-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-section-header__content-{{ ai_gen_id }}">
    {% if block.settings.show_overline and block.settings.overline_text != blank %}
      <p class="ai-section-header__overline-{{ ai_gen_id }}">
        {{ block.settings.overline_text }}
      </p>
    {% endif %}

    {% if block.settings.show_divider_top %}
      <hr class="ai-section-header__divider-{{ ai_gen_id }}">
    {% endif %}

    {% if block.settings.heading_text != blank %}
      <h2 class="ai-section-header__heading-{{ ai_gen_id }}">
        {{ block.settings.heading_text }}
      </h2>
    {% endif %}

    {% if block.settings.show_divider_bottom %}
      <hr class="ai-section-header__divider-{{ ai_gen_id }}">
    {% endif %}

    {% if block.settings.subheading_text != blank %}
      <p class="ai-section-header__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading_text }}
      </p>
    {% endif %}
  </div>
</div>

