{% doc %}
  @prompt
    carousel to feature my 3 offers
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-offers-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-offers-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-offers-carousel__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-offers-carousel__slide-{{ ai_gen_id }} {
    min-width: 100%;
    padding: 0 {{ block.settings.slide_padding }}px;
    box-sizing: border-box;
  }

  .ai-offers-carousel__card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-offers-carousel__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.content_spacing }}px;
  }

  .ai-offers-carousel__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-offers-carousel__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-offers-carousel__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-offers-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 600;
    letter-spacing: {{ block.settings.heading_letter_spacing }}%;
  }

  .ai-offers-carousel__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    flex-grow: 1;
  }

  .ai-offers-carousel__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }}%;
  }

  .ai-offers-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-offers-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.controls_spacing }}px;
  }

  .ai-offers-carousel__nav-button-{{ ai_gen_id }} {
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-offers-carousel__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
    transform: scale(1.1);
  }

  .ai-offers-carousel__nav-button-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    stroke: {{ block.settings.nav_button_icon_color }};
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-offers-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
  }

  .ai-offers-carousel__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    padding: 0;
  }

  .ai-offers-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-offers-carousel__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-offers-carousel__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-offers-carousel__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<offers-carousel-{{ ai_gen_id }} class="ai-offers-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-offers-carousel__container-{{ ai_gen_id }}">
    <div class="ai-offers-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign title_key = 'offer_' | append: i | append: '_title'
          assign description_key = 'offer_' | append: i | append: '_description'
          assign button_text_key = 'offer_' | append: i | append: '_button_text'
          assign button_link_key = 'offer_' | append: i | append: '_button_link'
          assign image_key = 'offer_' | append: i | append: '_image'

          assign title = block.settings[title_key]
          assign description = block.settings[description_key]
          assign button_text = block.settings[button_text_key]
          assign button_link = block.settings[button_link_key]
          assign image = block.settings[image_key]
        %}

        <div class="ai-offers-carousel__slide-{{ ai_gen_id }}" data-slide="{{ i }}">
          <div class="ai-offers-carousel__card-{{ ai_gen_id }}">
            <div class="ai-offers-carousel__image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 1200 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-offers-carousel__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-offers-carousel__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if title != blank %}
              <h3 class="ai-offers-carousel__title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}

            {% if description != blank %}
              <div class="ai-offers-carousel__description-{{ ai_gen_id }}">
                {{ description }}
              </div>
            {% endif %}

            {% if button_text != blank %}
              <div>
                <a
                  href="{{ button_link | default: '#' }}"
                  class="ai-offers-carousel__button-{{ ai_gen_id }}"
                >
                  {{ button_text }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ai-offers-carousel__controls-{{ ai_gen_id }}">
    <button
      class="ai-offers-carousel__nav-button-{{ ai_gen_id }} ai-offers-carousel__prev-{{ ai_gen_id }}"
      aria-label="Previous offer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="ai-offers-carousel__dots-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        <button
          class="ai-offers-carousel__dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
          data-slide="{{ i }}"
          aria-label="Go to offer {{ i }}"
        ></button>
      {% endfor %}
    </div>

    <button
      class="ai-offers-carousel__nav-button-{{ ai_gen_id }} ai-offers-carousel__next-{{ ai_gen_id }}"
      aria-label="Next offer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</offers-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class OffersCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = 3;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-offers-carousel__track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-offers-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-offers-carousel__next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-offers-carousel__dot-{{ ai_gen_id }}');

        this.prevButton.addEventListener('click', () => this.goToPrevSlide());
        this.nextButton.addEventListener('click', () => this.goToNextSlide());

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        {% if block.settings.enable_autoplay %}
          this.startAutoplay();
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        {% endif %}

        this.updateCarousel();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateCarousel();
      }

      goToNextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
        this.updateCarousel();
      }

      goToPrevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
        this.updateCarousel();
      }

      updateCarousel() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('offers-carousel-{{ ai_gen_id }}', OffersCarousel{{ ai_gen_id }});
  })();
</script>

